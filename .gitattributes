# Set default behavior to automatically normalize line endings
* text=auto

# Explicitly declare text files you want to always be normalized and converted to LF on commit
*.js text eol=lf
*.css text eol=lf
*.json text eol=lf
*.sql text eol=lf
*.md text eol=lf

# Denotate binary files to prevent Git from modifying their bytes
*.png filter=lfs diff=lfs merge=lfs -text
*.jpg filter=lfs diff=lfs merge=lfs -text
*.webp filter=lfs diff=lfs merge=lfs -text
*.ico filter=lfs diff=lfs merge=lfs -text
